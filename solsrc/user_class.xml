<?xml version="1.0" encoding="UTF-8"?>
<program language="SOL26">
  <class name="Main" parent="Object">
    <method selector="run">
      <block arity="0">
        <assign order="1">
          <var name="i"/>
          <expr>
            <send selector="new">
              <expr>
                <literal class="class" value="MyClass"/>
              </expr>
            </send>
          </expr>
        </assign>
        <assign order="2">
          <var name="_"/>
          <expr>
            <send selector="foo">
              <expr>
                <var name="i"/>
              </expr>
            </send>
          </expr>
        </assign>
      </block>
    </method>
  </class>
  <class name="MyClass" parent="Object">
    <method selector="foo">
      <block arity="0">
        <assign order="1">
          <var name="_"/>
          <expr>
            <send selector="print">
              <expr>
                <literal class="String" value="Hello from MyClass::foo"/>
              </expr>
            </send>
          </expr>
        </assign>
      </block>
    </method>
  </class>
</program>
